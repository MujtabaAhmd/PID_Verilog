`timescale 1ns / 1ps

module PID_TB;

    // Parameters
    parameter SIZE = 16; // Using 16-bit for better precision in the simulation
    
    // Inputs
    reg signed [SIZE-1:0] setpoint;
    reg signed [SIZE-1:0] point;
    reg signed [SIZE-1:0] K_p, K_d, K_i;
    reg clk;
    reg signed [SIZE-1:0] dt;
    reg reset;

    // Outputs
    wire signed [SIZE-1:0] u_t;

    // Instantiate the Unit Under Test (UUT)
    PID_Controller #(.SIZE(SIZE)) uut (
        .setpoint(setpoint), 
        .point(point), 
        .K_p(K_p), 
        .K_d(K_d), 
        .K_i(K_i), 
        .clk(clk), 
        .dt(dt), 
        .reset(reset), 
        .u_t(u_t)
    );

    // Clock generation (100MHz)
    always #5 clk = ~clk;

    // Simple Motor Model Variables
    real motor_position = 0.0;
    real motor_velocity = 0.0;
    real friction = 0.95; // Simple air resistance/friction factor

    initial begin
        // Initialize Inputs
        clk = 0;
        reset = 1;
        setpoint = 15;   // Target: 15 degrees
        point = 0;
        dt = 1;          // Time step
        
        // PID Gains (Tuned for a small motor model)
        K_p = 120;       // Proportional gain
        K_i = 10;        // Integral gain (slowly removes steady-state error)
        K_d = 50;        // Derivative gain (prevents overshoot)

        // Wait for global reset
        #100;
        reset = 0;

        // Simulation Loop: Simulate 2000 units of time
        repeat (500) begin
            @(posedge clk);
            
            // --- SIMPLE MOTOR PHYSICS MODEL ---
            // 1. Acceleration is proportional to PID output (u_t)
            // 2. Velocity updates based on acceleration
            motor_velocity = (motor_velocity + ($signed(u_t) * 0.01)) * friction;
            
            // 3. Position updates based on velocity
            motor_position = motor_position + motor_velocity;

            // 4. Feed the new position back into the PID 'point'
            point = $rtoi(motor_position); 

            // Monitor the values in the console
            $display("Time: %t | Setpoint: %d | Position: %d | Output(u_t): %d", 
                      $time, setpoint, point, u_t);
        end

        $finish;
    end

endmodule